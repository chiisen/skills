# Environment variables for Telegram Notify
# Copy this file to .env and fill in your actual values

# Get Bot Token: Create a Bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get Chat ID: Chat with your Bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here
